  "compatibility": [
    "claude-code",
    "codex",
    "generic-agent-skills"
  ],
  "safety": {
    "anti_fabrication": true,
    "real_data_required": true,
    "destructive_confirmation": "two DELETE confirmations",
    "destructive_action_schema": "schemas/destructive-action.schema.json"
  },
  "lifecycle": [
    "init",
    "PRD",
    "plan",
    "execute",
    "code_review",
    "review_fix_loop",
    "second_review",
    "multi_angle_review",
    "commit_readiness",
    "push",
    "complete"
  ],
  "canonical_lifecycle": "init → PRD → plan → execute → code review → review fix loop → second review → multi-angle review → commit readiness → push → complete",
  "maturity_tier": "production",
  "review_cadence": "quarterly",
  "license": "MIT",
  "public_repository_docs": [
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
